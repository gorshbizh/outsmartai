# LLM Configuration
# Set LLM_PROVIDER to 'openai' or 'anthropic'
LLM_PROVIDER=anthropic

# OpenAI API Key (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=openai_api_key_here

# Anthropic API Key (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=anthropic_api_key_here

# LLM_API_KEY is used by the app - set it based on your provider
LLM_API_KEY=any_llm_provider_api_key_here
# Server Configuration  
PORT=3000
BACKEND_PORT=5000
BACKEND_URL=http://localhost:5000
FLASK_DEBUG=False